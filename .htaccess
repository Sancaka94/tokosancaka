<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # --- 1. BAGIAN PENGECUALIAN (Exclusion List) ---
    # Agar folder-folder ini tidak ikut terlempar ke subdomain atau public
    
    RewriteRule ^bisnis\.pro - [L,NC]
    RewriteRule ^tokosancaka\.biz\.id - [L,NC]
    RewriteRule ^sancaka\.my\.id - [L,NC]
    RewriteRule ^spx\.tokosancaka\.com - [L,NC]
    RewriteRule ^sancaka\.bisnis\.pro - [L,NC]
    RewriteRule ^bisnis\.sancaka\.my\.id - [L,NC]
    RewriteRule ^scrapper($|/) - [L]

    # --- 2. WILDCARD SUBDOMAIN (PENCEGATAN DINAMIS) ---
    # Jika mengakses subdomain (misal: gemini.tokosancaka.com)
    # Tapi abaikan jika itu adalah www atau domain utama
    RewriteCond %{HTTP_HOST} !^www\.tokosancaka\.com$ [NC]
    RewriteCond %{HTTP_HOST} !^tokosancaka\.com$ [NC]
    # Ambil subdomainnya dan lempar secara internal ke folder percetakan/public
    RewriteCond %{HTTP_HOST} ^([^.]+)\.tokosancaka\.com$ [NC]
    # Gunakan pengecekan agar tidak looping jika sudah berada di folder percetakan
    RewriteCond %{REQUEST_URI} !^/percetakan/
    RewriteRule ^(.*)$ percetakan/public/$1 [L]

    # --- 3. ATURAN DEFAULT WEB UTAMA ---
    # Arahkan semua request domain utama ke folder public
    RewriteCond %{REQUEST_URI} !^/public/
    # Tambahkan pengecekan agar folder percetakan tidak ikut terlempar ke public utama
    RewriteCond %{REQUEST_URI} !^/percetakan/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php74___lsphp .php .php7 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit