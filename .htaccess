<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Tambahkan baris ini untuk mengabaikan folder percetakan
    # RewriteCond %{REQUEST_URI} !^/percetakan
    # RewriteCond %{REQUEST_URI} !^/indahcargo
    
    # --- BAGIAN PENGECUALIAN (Exclusion List) ---
    
    # 1. Bebaskan folder bisnis.pro
    RewriteRule ^bisnis\.pro - [L,NC]

    # 2. Bebaskan folder tokosancaka.biz.id (TAMBAHAN BARU)
    RewriteRule ^tokosancaka\.biz\.id - [L,NC]
    
    # 3. Bebaskan folder sancaka.my.id (BARU)
    RewriteRule ^sancaka\.my\.id - [L,NC]
    
    # 4. Bebaskan folder spx.tokosancaka.com (BARU)
    RewriteRule ^spx\.tokosancaka\.com - [L,NC]
    
    # 5. Bebaskan folder sancaka.bisnis.pro (BARU - Agar subdomain ini bisa diakses)
    RewriteRule ^sancaka\.bisnis\.pro - [L,NC]

    # --------------------------------------------
    
    RewriteRule ^scrapper($|/) - [L]

    # Arahkan semua request ke folder public
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php74” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php74___lsphp .php .php7 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
